{
	"schemaVersion": 1,
	"id": "calhas-moles",
	"version": "${version}",
	"name": "Calha's Moles",
	"description": "A mod that adds Moles to your Minecraft world!",
	"authors": [
		"Gabriel Brilha, Rafael Pedro, Pedro Morgado"
	],
	"contact": {
		"homepage": "",
		"sources": "https://github.com/gabrielbrilha/calhas-moles/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/calhas-moles/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"calhas.calhasmoles.CalhasMoles"
		],
		"client": [
			"calhas.calhasmoles.client.CalhasMolesClient"
		]
	},
	"mixins": [
		"calhas-moles.mixins.json",
		{
			"config": "calhas-moles.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}